#!/bin/bash
# Claude Code → Codex → Claude Code pipeline
# Visual orchestration: Tab A (plan+review) ↔ Tab B (codex exec)
set -euo pipefail

DEFAULT_CMUX="/Applications/cmux.app/Contents/Resources/bin/cmux"
if [ -n "${CMUX:-}" ]; then
  :
elif [ -x "$DEFAULT_CMUX" ]; then
  CMUX="$DEFAULT_CMUX"
else
  CMUX="$(command -v cmux 2>/dev/null || true)"
fi

fail() {
  echo "[preflight] ERROR: $*" >&2
  exit 1
}

warn() {
  echo "[preflight] WARN: $*" >&2
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "Missing command: $1"
}

check_preflight() {
  local missing=0

  echo "[preflight] Checking local requirements..."

  if [ -z "$CMUX" ] || [ ! -x "$CMUX" ]; then
    echo "[preflight] ERROR: cmux not found. Install cmux or set CMUX=/path/to/cmux." >&2
    missing=1
  fi

  for cmd in bash claude codex python3 git realpath find grep head tee sed cut sleep; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "[preflight] ERROR: Missing command: $cmd" >&2
      missing=1
    fi
  done

  [ "$missing" -eq 0 ] || exit 1

  "$CMUX" identify --json >/dev/null 2>&1 || fail "cmux is installed but this shell is not identifiable by cmux. Run the pipeline from a cmux terminal/session."
  python3 -c "import json,sys; json.load(sys.stdin)" >/dev/null 2>&1 < <("$CMUX" identify --json) || fail "cmux identify --json did not return valid JSON."
  claude --version >/dev/null 2>&1 || fail "claude CLI is installed but not usable. Check installation/login."
  codex --version >/dev/null 2>&1 || fail "codex CLI is installed but not usable. Check installation/login."

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    warn "Current directory is not a git repo. exec mode will use --skip-git-repo-check; tui mode may run git init."
  fi

  echo "[preflight] OK"
}

# ── Phase sub-command: Codex execution (runs in Tab B) ──
# Usage: --phase-exec <plan> <workdir> <signal> [exec|tui]
if [ "${1:-}" = "--phase-exec" ]; then
  [ -n "$CMUX" ] || fail "cmux not found. Set CMUX=/path/to/cmux."
  require_command codex
  require_command git
  PLAN_FILE="$2"; WORKDIR="$3"; SIGNAL="$4"; CODEX_MODE="${5:-exec}"
  signal_done() { "$CMUX" wait-for -S "$SIGNAL" 2>/dev/null || true; }
  trap signal_done EXIT

  CODEX_PROMPT="根据架构计划实现所有代码。遵守架构约束，实现细节由你决定。完成后用验收标准自检。"

  if [ "$CODEX_MODE" = "tui" ]; then
    # Interactive TUI: requires git, user /exit to continue
    if ! git -C "$WORKDIR" rev-parse --is-inside-work-tree &>/dev/null; then
      git init -q "$WORKDIR"
    fi
    codex -s workspace-write -C "$WORKDIR" \
      "读取 $PLAN_FILE 中的架构计划并实现。${CODEX_PROMPT} 完成后提示用户输入 /exit 以启动审核。"
  else
    # Exec mode: auto-exits, supports --skip-git-repo-check
    CODEX_ARGS=(-s workspace-write -C "$WORKDIR")
    if ! git -C "$WORKDIR" rev-parse --is-inside-work-tree &>/dev/null; then
      CODEX_ARGS+=(--skip-git-repo-check)
    fi
    cat "$PLAN_FILE" | codex exec "${CODEX_ARGS[@]}" "$CODEX_PROMPT"
  fi

  signal_done
  trap - EXIT
  exit 0
fi

# ── Main orchestrator (runs in Tab A) ──
# Usage: claude-codex-pipeline-cmux [--mode exec|tui] <task-description>
PRESET_MODE=""
if [ "${1:-}" = "--mode" ]; then
  PRESET_MODE="$2"
  shift 2
fi
[ "$#" -gt 0 ] || fail "Usage: claude-codex-pipeline-cmux [--mode exec|tui] <task-description>"
TASK="$*"
WORKDIR="$(pwd)"
RUN_ID=$$
PLAN_FILE="/tmp/pipeline-plan-${RUN_ID}.md"
REVIEW_FILE="/tmp/pipeline-review-${RUN_ID}.md"
SIGNAL="pipeline-done-${RUN_ID}"
SELF="$(realpath "$0")"

check_preflight

notify() { "$CMUX" notify --title "Pipeline" --body "$1" >/dev/null 2>&1 || true; }
progress() {
  # $1 = 0.0-1.0, $2 = label
  "$CMUX" set-progress "$1" --label "$2" >/dev/null 2>&1 || true
  "$CMUX" set-status pipeline "$2" --icon "bolt.fill" --color "#1a73e8" >/dev/null 2>&1 || true
  "$CMUX" log --level info --source "pipeline" "$2" >/dev/null 2>&1 || true
}
cleanup_progress() {
  "$CMUX" clear-progress >/dev/null 2>&1 || true
  "$CMUX" clear-status pipeline >/dev/null 2>&1 || true
}
trap cleanup_progress EXIT

# Check git repo status (Codex works better with git, but don't force it)
if git rev-parse --is-inside-work-tree &>/dev/null; then
  HAS_GIT=1
else
  HAS_GIT=0
  echo "[info] Not a git repo — Codex will use --skip-git-repo-check"
fi

# Get Tab A identifiers
TAB_A_PANE=$(  "$CMUX" identify --json 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['caller']['pane_ref'])")
TAB_A_SURFACE=$("$CMUX" identify --json 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['caller']['surface_ref'])")

# Rename Tab A
"$CMUX" rename-tab --surface "$TAB_A_SURFACE" "Plan+Review (Claude)" >/dev/null 2>&1 || true

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Claude→Codex Pipeline"
echo "  Task: $TASK"
echo "  Dir:  $WORKDIR"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ════════════════════════════════════
# Phase 1: Claude Code Plan (visible in Tab A)
# ════════════════════════════════════
echo ""
echo "━━━ Phase 1: Planning (Claude Code) ━━━"
progress 0.1 "Phase 1/3: Claude planning..."
notify "Phase 1/3: Claude planning..."

DIR_LISTING=$(ls -la "$WORKDIR" 2>/dev/null | head -30)
FILE_TREE=$(find "$WORKDIR" -maxdepth 3 -type f -not -path '*/.git/*' 2>/dev/null | head -50)

claude -p --output-format text \
  --allowedTools "Read" \
  --no-session-persistence \
  "你是高级架构师。只输出架构级实现计划，不要写具体代码实现。
代码由下游执行者（Codex）自主编写，你只需要给出清晰的架构指导。

任务：$TASK
工作目录：$WORKDIR

当前目录：
$DIR_LISTING

文件树：
$FILE_TREE

输出（Markdown）：
1. 概述（方案思路，1-2 句）
2. 文件清单（每个文件的职责、对外接口，不写具体实现代码）
3. 架构约束（技术选型、依赖限制、安全要求、性能要求）
4. 关键设计决策（为什么这样设计，有什么 tradeoff）
5. 验收标准（具体的功能测试用例，执行者可用来自检）

不要写代码。不要写 HTML/CSS/JS 片段。只描述要做什么、怎么组织、满足什么标准。
让执行者自主决定实现细节。" | tee "$PLAN_FILE"

echo ""
echo "━━━ Phase 1 Complete ━━━"
progress 0.3 "Phase 1 done"
notify "Phase 1: Plan ready"

# ── Determine Codex mode: --mode arg > interactive prompt > default exec ──
if [ -n "$PRESET_MODE" ]; then
  case "$PRESET_MODE" in
    tui)  CODEX_MODE="tui" ;;
    *)    CODEX_MODE="exec" ;;
  esac
  echo "[Orchestrator] Codex mode: $CODEX_MODE (from --mode arg)"
elif [ -t 0 ]; then
  # Interactive terminal — ask user
  echo ""
  echo "选择 Codex 执行模式："
  echo "  1) exec  — 自动执行，完成即退出（推荐）"
  echo "  2) tui   — 交互式界面，完成后可追问，/exit 退出触发审核"
  echo ""
  printf "输入 1 或 2 [默认 1]: "
  read -r MODE_CHOICE
  case "$MODE_CHOICE" in
    2|tui) CODEX_MODE="tui" ;;
    *)     CODEX_MODE="exec" ;;
  esac
  echo "[Orchestrator] Codex mode: $CODEX_MODE"
else
  # Non-interactive (background, piped) — default to exec
  CODEX_MODE="exec"
  echo "[Orchestrator] Non-interactive stdin — defaulting to exec mode (use --mode tui to override)"
fi

# ════════════════════════════════════
# Phase 2: Create Tab B, launch Codex
# ════════════════════════════════════
echo ""
echo "[Orchestrator] Creating Tab B for Codex..."

# Create right split and focus it so identify can reliably find Tab B if refs
# are not included in new-split output.
set +e
SPLIT_OUT=$("$CMUX" new-split right --focus true 2>/dev/null)
SPLIT_STATUS=$?
set -e

TAB_B_SURFACE=$(printf '%s\n' "$SPLIT_OUT" | grep -o 'surface:[0-9]*' | head -1 || true)
TAB_B_PANE=$(printf '%s\n' "$SPLIT_OUT" | grep -o 'pane:[0-9]*' | head -1 || true)

if [ "$SPLIT_STATUS" -eq 0 ] && { [ -z "$TAB_B_SURFACE" ] || [ -z "$TAB_B_PANE" ]; }; then
  FOCUSED_JSON=$("$CMUX" identify --json 2>/dev/null || true)
  if [ -n "$FOCUSED_JSON" ]; then
    TAB_B_SURFACE=${TAB_B_SURFACE:-$(printf '%s\n' "$FOCUSED_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('focused',{}).get('surface_ref',''))" 2>/dev/null || true)}
    TAB_B_PANE=${TAB_B_PANE:-$(printf '%s\n' "$FOCUSED_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('focused',{}).get('pane_ref',''))" 2>/dev/null || true)}
  fi
fi

if [ "$SPLIT_STATUS" -ne 0 ] || [ -z "$TAB_B_SURFACE" ]; then
  echo "[Error] Failed to create Tab B. Running Codex in Tab A..."
  CODEX_FALLBACK_ARGS=(-s workspace-write)
  if [ "$HAS_GIT" -eq 0 ]; then
    CODEX_FALLBACK_ARGS+=(--skip-git-repo-check)
  fi
  set +e
  cat "$PLAN_FILE" | codex exec "${CODEX_FALLBACK_ARGS[@]}" \
    "根据 stdin 中的架构计划实现代码。计划描述了文件结构、接口、约束和验收标准。你负责自主编写所有实现代码。遵守计划中的架构约束，但实现细节由你决定。完成后用验收标准自检。"
  CODEX_STATUS=${PIPESTATUS[1]}
  set -e
  if [ "$CODEX_STATUS" -ne 0 ]; then
    echo "[Error] Codex failed in fallback mode (exit $CODEX_STATUS). Continuing to review current diff."
  fi
else
  echo "[Orchestrator] Tab B: $TAB_B_SURFACE"

  # Rename Tab B
  "$CMUX" rename-tab --surface "$TAB_B_SURFACE" "Execute (Codex)" >/dev/null 2>&1 || true

  # Run phase-exec directly via respawn-pane
  "$CMUX" respawn-pane --surface "$TAB_B_SURFACE" \
    --command "'$SELF' --phase-exec '$PLAN_FILE' '$WORKDIR' '$SIGNAL' '$CODEX_MODE'" >/dev/null 2>&1

  if [ -n "$TAB_B_PANE" ]; then
    "$CMUX" focus-pane --pane "$TAB_B_PANE" >/dev/null 2>&1 || true
  fi

  if [ "$CODEX_MODE" = "tui" ]; then
    echo "[Orchestrator] Codex TUI running in Tab B. 完成后输入 /exit 触发审核。"
    progress 0.4 "Phase 2/3: Codex TUI (/exit to continue)"
    notify "Phase 2/3: Codex TUI — /exit 触发审核"
  else
    echo "[Orchestrator] Codex exec running in Tab B. Waiting..."
    progress 0.4 "Phase 2/3: Codex executing..."
    notify "Phase 2/3: Codex executing in Tab B"
  fi

  # Wait for Codex to finish (signal or timeout)
  "$CMUX" wait-for "$SIGNAL" --timeout 600 >/dev/null 2>&1 || true

  echo "[Orchestrator] Codex complete. Switching back..."
  progress 0.7 "Phase 2 done — opening preview"
  notify "Phase 2 complete — starting review"

  # Focus back to Tab A
  "$CMUX" focus-pane --pane "$TAB_A_PANE" >/dev/null 2>&1 || true
fi

# ════════════════════════════════════
# Phase 2.5: Open result in browser (if HTML exists)
# ════════════════════════════════════
INDEX_FILE="$WORKDIR/index.html"
if [ -f "$INDEX_FILE" ]; then
  echo ""
  echo "[Orchestrator] Opening result in browser..."
  # Try cmux built-in browser first, fall back to system browser
  if "$CMUX" browser open "file://$INDEX_FILE" --focus false >/dev/null 2>&1; then
    echo "[Orchestrator] Opened in cmux browser"
  elif open -a "Google Chrome" "$INDEX_FILE" 2>/dev/null; then
    echo "[Orchestrator] Opened in Google Chrome"
  elif open "$INDEX_FILE" 2>/dev/null; then
    echo "[Orchestrator] Opened in default browser"
  else
    echo "[Orchestrator] Could not open browser — open manually: $INDEX_FILE"
  fi
fi

# ════════════════════════════════════
# Phase 3: Claude Code Review (visible in Tab A)
# ════════════════════════════════════
echo ""
echo "━━━ Phase 3: Review (Claude Code) ━━━"
progress 0.8 "Phase 3/3: Claude reviewing..."
notify "Phase 3/3: Claude reviewing..."

PLAN_CONTENT=$(cat "$PLAN_FILE")
DIFF=""
DIFF_STAGED=""
NEW_FILES=""

if [ "$HAS_GIT" -eq 1 ]; then
  DIFF=$(git diff 2>/dev/null || echo "")
  DIFF_STAGED=$(git diff --cached 2>/dev/null || echo "")
  UNTRACKED=$(git ls-files --others --exclude-standard 2>/dev/null || echo "")
  if [ -n "$UNTRACKED" ]; then
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      NEW_FILES="${NEW_FILES}
--- $f ---
$(head -100 "$WORKDIR/$f" 2>/dev/null || echo "(unreadable)")
"
    done <<< "$UNTRACKED"
  fi
else
  # No git — collect all non-hidden files for review
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    REL="${f#$WORKDIR/}"
    NEW_FILES="${NEW_FILES}
--- $REL ---
$(head -100 "$f" 2>/dev/null || echo "(unreadable)")
"
  done < <(find "$WORKDIR" -maxdepth 3 -type f -not -path '*/.*' 2>/dev/null)
fi

claude -p --output-format text \
  --allowedTools "Read" \
  --no-session-persistence \
  "你是代码审核专家。只输出审核报告，不要修改任何文件。

重要：你有 Read 权限。审核前先用 Read 工具读取实际文件内容，不要仅依赖下面的摘要（可能被截断）。

## 原始计划
$PLAN_CONTENT

## 工作目录
$WORKDIR

## 参考信息（可能不完整，请用 Read 验证）
${DIFF:+### git diff
\`\`\`diff
${DIFF}${DIFF_STAGED:+
--- staged ---
$DIFF_STAGED}
\`\`\`
}
${NEW_FILES:+### 文件摘要
$NEW_FILES}

## 审核流程
1. 先用 Read 读取每个文件的完整内容
2. 对照计划逐项检查
3. 输出审核报告

## 审核维度
1. 计划符合度 — 每项是否实现？遗漏或多余？
2. 安全性 — XSS、注入、硬编码密钥？
3. 正确性 — 逻辑、边界条件？
4. 质量 — 命名、结构、过度工程？

输出：PASS/WARN/FAIL + 发现 + 建议" | tee "$REVIEW_FILE"

# Extract review verdict for the notification
VERDICT=$(grep -oE "(PASS|WARN|FAIL)" "$REVIEW_FILE" 2>/dev/null | head -1 || echo "")
progress 1.0 "✓ ${VERDICT:-完成} — 输入 read the output file 查看审核"
notify "✓ ${VERDICT:-完成} — 在 Claude Code 输入：read the output file"
"$CMUX" trigger-flash >/dev/null 2>&1 || true

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Pipeline Complete"
echo "  Plan:   $PLAN_FILE"
echo "  Review: $REVIEW_FILE"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── Compact summary block (so folded previews surface the verdict) ──
echo ""
echo "━━━ Review Summary ━━━"
echo "Verdict: ${VERDICT:-UNKNOWN}"
CRIT_COUNT=$({ grep -ciE 'critical' "$REVIEW_FILE" 2>/dev/null; } || true)
HIGH_COUNT=$({ grep -ciE '(^|[^a-z])high([^a-z]|$)' "$REVIEW_FILE" 2>/dev/null; } || true)
WARN_COUNT=$({ grep -ciE '(^|[^a-z])warn([^a-z]|$)' "$REVIEW_FILE" 2>/dev/null; } || true)
echo "Mentions: Critical=${CRIT_COUNT:-0} / High=${HIGH_COUNT:-0} / Warn=${WARN_COUNT:-0}"
# Pull the first 3 bullet/numbered lines (truncated to 160 chars each)
TOP_FINDINGS=$(grep -E '^([0-9]+\.|[-*])\s+\S' "$REVIEW_FILE" 2>/dev/null | head -3 | cut -c 1-160)
if [ -n "$TOP_FINDINGS" ]; then
  echo "Top findings:"
  echo "$TOP_FINDINGS" | sed 's/^/  /'
fi
echo "Full report: $REVIEW_FILE"
echo "━━━━━━━━━━━━━━━━━━━━━━━"

# ── Auto-inject "read the output file" into Tab A (the Claude Code TUI) ──
if [ -n "${TAB_A_SURFACE:-}" ]; then
  # Small delay to make sure Tab A finished rendering completion notification
  sleep 1
  "$CMUX" send --surface "$TAB_A_SURFACE" "read the output file" >/dev/null 2>&1 || true
  "$CMUX" send-key --surface "$TAB_A_SURFACE" Enter >/dev/null 2>&1 || true
fi
